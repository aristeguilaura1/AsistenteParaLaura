# ⚙️ Configuración del AsistenteParaLaura
# Copia este archivo a .env y personaliza los valores

# 📧 Email principal (destinatario de notificaciones)
EMAIL_DESTINATARIO=tu_email@epamneoris.com

# 📧 Email en copia (CC)
EMAIL_CC=supervisor@epamneoris.com

# 🔗 URL del sistema de timecard
TIMECARD_URL=https://hc.neoris.net/timecard/

# ⏰ Horas por día laboral
HORAS_POR_DIA=8

# 🔧 Configuraciones avanzadas (opcional)
# TIMEOUT_SEGUNDOS=15
# DEBUG_MODE=false
